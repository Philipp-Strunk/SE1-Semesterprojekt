        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;classDiagram\n\n    class Main {\n        +main(args: String[]) void\n    }\n\n    class InputDialog {\n        -container: Container\n        +startEingabe() void\n    }\n\n    class CommandHandler {\n        -commands: Map~String, Command~\n        -context: CommandContext\n        +handle(input: String) void\n    }\n\n    class CommandContext {\n        -container: Container\n        -actorRegistry: ActorRegistry\n        -undoHistory: Stack~UndoAction~\n        +addUndoAction(action: UndoAction) void\n        +getLastUndoAction() UndoAction\n        +requestExit() void\n    }\n\n    class Command {\n        &lt;&lt;interface&gt;&gt;\n        +execute(context: CommandContext, args: String[]) void\n        +getDescription() String\n    }\n\n    class EnterCommand\n    class DumpCommand\n    class StoreCommand\n    class LoadCommand\n    class AnalyzeCommand\n    class AddElementCommand\n    class UndoCommand\n\n    Command &lt;|.. EnterCommand\n    Command &lt;|.. DumpCommand\n    Command &lt;|.. StoreCommand\n    Command &lt;|.. LoadCommand\n    Command &lt;|.. AnalyzeCommand\n    Command &lt;|.. AddElementCommand\n    Command &lt;|.. UndoCommand\n\n    class UndoAction {\n        &lt;&lt;interface&gt;&gt;\n        +undo() void\n    }\n\n    class RemoveUserStoryUndoAction\n    class RemoveActorUndoAction\n\n    UndoAction &lt;|.. RemoveUserStoryUndoAction\n    UndoAction &lt;|.. RemoveActorUndoAction\n\n    class Container {\n        -userStories: List~UserStory~\n        -strategy: PersistenceStrategy~UserStory~\n        +addUserStory(userStory: UserStory) void\n        +removeUserStory(id: int) boolean\n        +getCurrentList() List~UserStory~\n        +store() void\n        +load() void\n    }\n\n    class UserStory {\n        -id: int\n        -title: String\n        -acceptanceCriterion: String\n        -value: int\n        -penalty: int\n        -effort: int\n        -risk: int\n        -priority: double\n        -project: String\n        +calculatePriority() void\n    }\n\n    class ActorRegistry {\n        -actors: List~String~\n        +addActor(actor: String) boolean\n        +removeActor(actor: String) boolean\n        +containsActor(actor: String) boolean\n        +getActors() List~String~\n    }\n\n    class PersistenceStrategy {\n        &lt;&lt;interface&gt;&gt;\n        +save(list: List~E~) void\n        +load() List~E~\n    }\n\n    class PersistenceStrategyStream\n    class PersistenceStrategyMongoDB\n\n    PersistenceStrategy &lt;|.. PersistenceStrategyStream\n    PersistenceStrategy &lt;|.. PersistenceStrategyMongoDB\n\n    class MongoDBControllerInterface {\n        &lt;&lt;interface&gt;&gt;\n    }\n\n    class MongoDBControllerImpl\n\n    MongoDBControllerInterface &lt;|.. MongoDBControllerImpl\n    PersistenceStrategyMongoDB --&gt; MongoDBControllerInterface\n\n    class UserStoryAnalyzer {\n        -actorRegistry: ActorRegistry\n        -rules: List~QualityRule~\n        +analyze(userStory: UserStory) AnalysisResult\n    }\n\n    class QualityRule {\n        &lt;&lt;interface&gt;&gt;\n        +isBroken(userStory: UserStory, actorRegistry: ActorRegistry) boolean\n        +getPenalty() int\n        +getDetail() String\n        +getHint() String\n    }\n\n    class KnownActorRule\n    class FunctionalityRule\n    class WrittenBenefitRule\n\n    QualityRule &lt;|.. KnownActorRule\n    QualityRule &lt;|.. FunctionalityRule\n    QualityRule &lt;|.. WrittenBenefitRule\n\n    class AnalysisResult {\n        -quality: int\n        -rating: String\n        -details: List~String~\n        -hints: List~String~\n    }\n\n    class UserStoryView {\n        +startAusgabe(userStories: List~UserStory~) void\n    }\n\n    Main --&gt; Container\n    Main --&gt; InputDialog\n\n    InputDialog --&gt; CommandHandler\n    CommandHandler o--&gt; Command\n    CommandHandler --&gt; CommandContext\n\n    CommandContext --&gt; Container\n    CommandContext --&gt; ActorRegistry\n    CommandContext o--&gt; UndoAction\n\n    EnterCommand --&gt; UserStory\n    DumpCommand --&gt; UserStoryView\n    AnalyzeCommand --&gt; UserStoryAnalyzer\n\n    Container o--&gt; UserStory\n    Container --&gt; PersistenceStrategy\n\n    UserStoryAnalyzer --&gt; ActorRegistry\n    UserStoryAnalyzer o--&gt; QualityRule\n    UserStoryAnalyzer --&gt; AnalysisResult\n    UserStoryAnalyzer --&gt; UserStory\n\n    UserStoryView --&gt; UserStory&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="TVZ6nOqLMul0nP_VqAq0-15">
